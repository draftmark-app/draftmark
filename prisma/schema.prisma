generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  emailVerifiedAt DateTime? @map("email_verified_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  docs           Doc[]
  collections    Collection[]
  accountApiKeys AccountApiKey[]
  loginTokens    LoginToken[]

  @@map("users")
}

model LoginToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  token     String    @unique // SHA-256 hashed
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("login_tokens")
}

model AccountApiKey {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  name       String    @default("default")
  key        String    @unique // SHA-256 hashed
  lastUsedAt DateTime? @map("last_used_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account_api_keys")
}

model Doc {
  id          String       @id @default(cuid())
  slug        String       @unique
  seoSlug     String?      @unique @map("seo_slug")
  title       String?
  content     String
  visibility      String    @default("public") // "public" | "private"
  status          String    @default("open") // "open" | "review_closed"
  magicToken      String    @map("magic_token") // hashed
  apiKey          String    @map("api_key") // hashed
  shareToken      String?   @unique @map("share_token") // unhashed, read-only access for private docs
  viewsCount      Int       @default(0) @map("views_count")
  expectedReviews Int?      @map("expected_reviews")
  reviewDeadline  DateTime? @map("review_deadline")
  meta            Json?     @db.JsonB
  userId          String?   @map("user_id")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  user           User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  versions       DocVersion[]
  comments       Comment[]
  reactions      Reaction[]
  reviews        Review[]
  collectionDocs CollectionDoc[]

  @@map("docs")
}

model DocVersion {
  id            String   @id @default(cuid())
  docId         String   @map("doc_id")
  content       String
  versionNote   String?  @map("version_note")
  versionNumber Int      @map("version_number")
  createdAt     DateTime @default(now()) @map("created_at")
  doc           Doc      @relation(fields: [docId], references: [id], onDelete: Cascade)

  @@map("doc_versions")
}

model Comment {
  id           String    @id @default(cuid())
  docId        String    @map("doc_id")
  body         String
  author       String    @default("anonymous")
  anchorType   String?   @map("anchor_type") // "line" | "selection" | null (general comment)
  anchorRef    Int?      @map("anchor_ref") // line number, null for general/selection
  anchorText   String?   @map("anchor_text") // selected text quote for selection comments
  docVersion   Int?      @map("doc_version") // version of doc when comment was made
  authorType   String    @default("human") @map("author_type") // "human" | "agent"
  status       String    @default("open") // "open", "resolved", "dismissed"
  crossRefSlug String?   @map("cross_ref_slug")
  crossRefLine Int?      @map("cross_ref_line")
  parentId     String?   @map("parent_id")
  createdAt    DateTime  @default(now()) @map("created_at")
  doc          Doc       @relation(fields: [docId], references: [id], onDelete: Cascade)
  parent       Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies      Comment[] @relation("CommentReplies")

  @@map("comments")
}

model Reaction {
  id         String   @id @default(cuid())
  docId      String   @map("doc_id")
  emoji      String   // "thumbs_up" | "check" | "thinking" | "cross"
  identifier String   // for dedup — one per emoji per doc per identifier
  createdAt  DateTime @default(now()) @map("created_at")
  doc        Doc      @relation(fields: [docId], references: [id], onDelete: Cascade)

  @@unique([docId, emoji, identifier])
  @@map("reactions")
}

model Review {
  id           String   @id @default(cuid())
  docId        String   @map("doc_id")
  reviewerName String   @default("anonymous") @map("reviewer_name")
  reviewerType String   @default("human") @map("reviewer_type") // "human" | "agent"
  identifier   String   // for dedup — one review per doc per identifier
  createdAt    DateTime @default(now()) @map("created_at")
  doc          Doc      @relation(fields: [docId], references: [id], onDelete: Cascade)

  @@unique([docId, identifier])
  @@map("reviews")
}

model Collection {
  id         String          @id @default(cuid())
  slug       String          @unique
  title      String
  magicToken String          @map("magic_token") // hashed
  apiKey     String          @map("api_key") // hashed
  userId     String?         @map("user_id")
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")
  user       User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  docs       CollectionDoc[]

  @@map("collections")
}

model CollectionDoc {
  id           String     @id @default(cuid())
  collectionId String     @map("collection_id")
  docId        String     @map("doc_id")
  position     Int        @default(0)
  label        String?
  createdAt    DateTime   @default(now()) @map("created_at")
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  doc          Doc        @relation(fields: [docId], references: [id], onDelete: Cascade)

  @@unique([collectionId, docId])
  @@map("collection_docs")
}
