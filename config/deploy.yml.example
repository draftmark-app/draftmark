service: draftmark

image: your-org/draftmark

servers:
  web:
    - YOUR_SERVER_IP

proxy:
  ssl: true
  host: your-domain.com
  app_port: 3000
  healthcheck:
    path: /up

registry:
  server: ghcr.io
  username: YOUR_GITHUB_USERNAME
  password:
    - KAMAL_REGISTRY_PASSWORD

env:
  clear:
    NEXT_PUBLIC_BASE_URL: https://your-domain.com
  secret:
    - DATABASE_URL
    - RESEND_API_KEY
    - JWT_SECRET
    - OPENROUTER_API_KEY

ssh:
  keys: ["~/.ssh/id_ed25519"]
  keys_only: true

builder:
  arch: amd64

accessories:
  db:
    image: postgres:17-alpine
    host: YOUR_SERVER_IP
    port: "127.0.0.1:5436:5432"
    env:
      clear:
        POSTGRES_USER: draftmark
        POSTGRES_DB: draftmark_production
      secret:
        - POSTGRES_PASSWORD
    directories:
      - data:/var/lib/postgresql/data
