# Database (Docker Compose default)
DATABASE_URL="postgres://draftmark:draftmark@localhost:5434/draftmark_development"

# Auth — generate a strong secret for production: openssl rand -base64 32
JWT_SECRET="dev-secret-change-in-production"

# Base URL for links in emails and API responses
NEXT_PUBLIC_BASE_URL="http://localhost:3333"

# Email (optional) — sign up at https://resend.com
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stakeholder views AI rewriting (optional) — sign up at https://openrouter.ai
# OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
